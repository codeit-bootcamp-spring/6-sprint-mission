name: Deploy discodeit to ECS

on:
  push:
    branches: [ release ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      # 1. 소스 코드 체크아웃 및 Gradle 환경 설정
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          java-version: '17'
          distribution: 'corretto'

      - name: Grant execute permission for gradlew
        run: chmod +x gradlew

      - name: Build with Gradle
        run: ./gradlew build


      # 2. AWS 인증 및 Public ECR 로그인
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v1
        with:
          aws-access-key-id: ${{ secrets.AWS_DEPLOY_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_DEPLOY_SECRET_ACCESS_KEY }}
          aws-region: ${{ variables.AWS_REGION_PUBLIC }}

      - name: Login to Amazon ECR
        id: login-ecr
        uses: aws-actions/amazon-ecr-login@v1


      # 3. Docker 이미지 빌드, ECR 푸시
      - name: Set environment variables for tagging
        run: |
          echo "ECR_REGISTRY=${{ secrets.AWS_ACCOUNT_ID }}.dkr.ecr.${{ variables.AWS_REGION_PUBLIC }}.amazonaws.com" >> $GITHUB_ENV
          echo "ECR-REPOSITORY=&{{}}.dkr.ecr.${{ variables.AWS_REGION_PUBLIC }}" >> $GITHUB_ENV
          echo "IMAGE_TAG=$(date + '%Y%m%d%H%M%S')-${GITHUB_SHA::8}" >> $GITHUB_ENV

      - name: Build Docker image
        run: docker build --platform linux/amd64 -t discodeit:latest .

      - name: Tag Docker image
        run: |
          docker tag discodeit:latest ${{variables.ECR_REPOSITORY_URI}}:${{ github.sha }}
          docker tag discodeit:latest ${{variables.ECR_REPOSITORY_URI}}:latest

      - name: Push Docker image to ECR
        run: |
          docker push ${{variables.ECR_REPOSITORY_URI}}:${{ github.sha }}
          docker push ${{variables.ECR_REPOSITORY_URI}}:latest


  update_ecs_service:
    needs: [ build ]
    runs-on: ubuntu-latest
    steps:
      # 4. CLI 설정
      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-region: ${{ variables.AWS_REGION }}
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}

      # 5. 기존 태스크 정의 기반으로 새 이미지로 업데이트
      - name: Download task definition template
        run: |
          aws ecs describe-task-definition --task-definition image-post-task --query taskDefinition > task-definition.json



      # 6. 프리티어 고려하여 기존 구동 서비스 중단 (desired-count=0 활용)
      - name: Stop existing ECS service for cost saving (desired-count=0)
        run: |
          aws ecs update-service \
          --cluster ${{ variables.ECS_CLUSTER }} \
          --service ${{ variables.ECS_SERVICE }} \
          --desired-count 0 \
          --force-new-deployment

          echo "Waiting for service to stop all running tasks..."

        # 서비스가 안정화(모든 작업 중단)될 때까지 대기
          aws ecs wait services-stable \
          --cluster ${{ variables.ECS_CLUSTER }} \
          --services ${{ variables.ECS_SERVICE }}

      # 7. 태스크 정의 업데이트 = 배포
      - name: Download task definition template
        run: |
          aws ecs describe-task-definition --task-definition discodeit-task --query taskDefinition > task-definition.json

      - name: Fill in the new image ID in the Amazon ECS task definition
        id: render-task-def
        uses: aws-actions/amazon-ecs-render-task-definition@v1
        with:
          task-definition: task-definition.json # 다운로드한 파일 경로
          container-name: discodeit # 업데이트할 컨테이너 이름
          image: ${{ needs.build.outputs.ecr_registry }}/${{ needs.build.outputs.ecr_repository }}:${{ needs.build.outputs.image_tag }} # build job의 output 사용 (job 간 output 설정 필요)
          # 환경 변수 등도 여기서 업데이트 가능 (선택 사항)
          environment-variables: |
            SPRING_PROFILES_ACTIVE=dev
            DEPLOY_TIME=${{ github.sha }}

      - name: Deploy Amazon ECS task definition
        uses: aws-actions/amazon-ecs-deploy-task-definition@v1
        with:
          task-definition: ${{ steps.render-task-def.outputs.task-definition }} # 업데이트된 작업 정의 파일 경로
          service: ${{ variables.ECS_SERVICE }} # 업데이트할 서비스 이름
          cluster: ${{ variables.ECS_CLUSTER }} # 클러스터 이름
          wait-for-service-stability: true # 배포 안정화 대기 (권장)

      - name: Verify deployment status
        run: |
          echo "✅ Deployment completed successfully and service is stable."



      - name: Verify deployment status
        run: |
          echo "✅ Deployment completed successfully and service is stable with task definition: ${{ env.NEW_TASK_DEFINITION_ARN }}"