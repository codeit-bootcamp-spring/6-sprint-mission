# Application
PROJECT_NAME=discodeit
PROJECT_VERSION=1.2-M8
JVM_OPTS=
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/discodeit
SPRING_DATASOURCE_USERNAME=discodeit
SPRING_DATASOURCE_PASSWORD=discodeit

# Database
POSTGRES_DB=discodeit
POSTGRES_USER=discodeit
POSTGRES_PASSWORD=discodeit

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT_PATH=.discodeit/storage

# AWS S3 (필요 시에만 설정)
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=
AWS_S3_BUCKET=
AWS_S3_PRESIGNED_URL_EXPIRATION=600
